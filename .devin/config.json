{
  // Project-level Devin for Terminal configuration
  // Committed to repo — do not put secrets here.
  // Use .devin/config.local.json (gitignored) for API keys and tokens.

  "permissions": {
    "allow": [
      "Read(**)",
      "Exec(npm install)",
      "Exec(npm run lint)",
      "Exec(npm start)",
      "Exec(node **)",
      "Exec(git *)"
    ],
    "deny": [
      "Exec(rm -rf **)",
      "Exec(curl ** | bash)"
    ]
  }
}
