# ===========================================
# Acme Commerce - Environment Configuration
# ===========================================

# App
PORT=3000
NODE_ENV=production
APP_VERSION=1.0.0
APP_SCENARIO=healthy

# Domain & SSL (for Nginx reverse proxy + Let's Encrypt)
DOMAIN_NAME=devindemos.com
CERT_EMAIL=shawn.d.azman@gmail.com

# Sentry
SENTRY_DSN=https://your-dsn@o123456.ingest.sentry.io/789
SENTRY_ENVIRONMENT=prod
SENTRY_RELEASE=acme-checkout@1.0.0

# Datadog
DD_API_KEY=your-datadog-api-key
DD_SITE=datadoghq.com
DD_ENV=prod
DD_SERVICE=checkout-api
DD_VERSION=1.0.0
DD_AGENT_HOST=datadog-agent
DD_TRACE_AGENT_PORT=8126
DD_DOGSTATSD_PORT=8125

# Slack (alert notifications — optional)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=C0123456789
SLACK_USER_TOKEN=xoxp-your-slack-user-token

# Devin API (auto-investigation via v3 service key)
# DEVIN_SERVICE_KEY is the service user's API key used for all session creation.
# Sessions are created on behalf of individual users via create_as_user_id.
DEVIN_SERVICE_KEY=your-devin-service-key
DEVIN_ORG_ID=your-devin-org-id
DEVIN_ORG_NAME=Devin GTM
DEVIN_PLAYBOOK_ID=

# Optional: fallback org list when enterprise API listing is unavailable.
# JSON array of {org_id, name} objects.
# DEVIN_ORG_LIST=[{"org_id":"org_abc","name":"My Org"}]

# Optional: fallback user list when API listing is unavailable.
# JSON array of {user_id, name, email} objects.
# DEVIN_ORG_USERS=[{"user_id":"cog_abc","name":"Alice","email":"alice@example.com"}]

# GitHub Webhook
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# SonarCloud remediation target repo (default: <GITHUB_ORG>/etl-pipeline-demo)
SONAR_TARGET_REPO=

# ─── Deployment Configuration ──────────────────────────
# GitHub organization for repo references (default: COG-GTM)
GITHUB_ORG=COG-GTM

# App display title (shown in hub page header)
# APP_TITLE=Event-Driven Devin

# Lock deployment to a single Devin org (hides org selector in UI).
# Set to any non-empty value for customer-specific demos.
# When set, DEVIN_ORG_ID determines which org is used.
# LOCK_ORG=true

# Pre-configured Devin user ID (hides user selector in UI).
# When set, all sessions are created as this user.
# DEVIN_USER_ID=cog_abc123...

# ─── Per-Customer Overrides ─────────────────────────────
# Customer-specific env vars use a _<SLUG> suffix.
# See config/customers.js for registered customer slugs.
#
# Example: Wayfair (customer slug: "wayfair")
# DEVIN_API_KEY_WAYFAIR=dv-your-wayfair-devin-api-key
# DEVIN_PLAYBOOK_ID_WAYFAIR=
# GITHUB_ORG_WAYFAIR=WayfairGitHubOrg
# DEVIN_USER_ID_WAYFAIR=cog_wayfair_user
# SONAR_TARGET_REPO_WAYFAIR=WayfairGitHubOrg/etl-pipeline-demo

# Zaxby's (customer slug: "zaxbys")
# DEVIN_API_KEY_ZAXBYS=dv-your-zaxbys-devin-api-key
# DEVIN_PLAYBOOK_ID_ZAXBYS=
# GITHUB_ORG_ZAXBYS=ZaxbysGitHubOrg
# DEVIN_USER_ID_ZAXBYS=cog_zaxbys_user
# SONAR_TARGET_REPO_ZAXBYS=ZaxbysGitHubOrg/etl-pipeline-demo

# Load Generator
LOADGEN_TARGET_URL=http://localhost:3000
LOADGEN_INTERVAL_MS=60000
