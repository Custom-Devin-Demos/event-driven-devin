# ===========================================
# Acme Commerce - Environment Configuration
# ===========================================

# App
PORT=3000
NODE_ENV=production
APP_VERSION=1.0.0
APP_SCENARIO=healthy

# Eli Lilly demo — legacy on-prem inventory service (cloud-migration target)
# Base URL the cloud dashboard uses to reach the on-prem system.
# Local: http://localhost:4001  |  Docker: http://onprem-legacy:4001
ONPREM_BASE_URL=http://onprem-legacy:4001

# Domain & SSL (for Nginx reverse proxy + Let's Encrypt)
DOMAIN_NAME=devindemos.com
CERT_EMAIL=your-email@example.com

# Sentry
SENTRY_DSN=https://your-dsn@o123456.ingest.sentry.io/789
SENTRY_ENVIRONMENT=prod
SENTRY_RELEASE=acme-checkout@1.0.0
# Fraction of requests traced for performance (spans). 1.0 = 100%, 0.1 = 10%, 0 = off.
# Lowering this is the primary lever to reduce Sentry span volume. Errors and the
# Slack/Devin alert pipeline are unaffected. Default: 0.1
SENTRY_TRACES_SAMPLE_RATE=0.1
# Fraction of traced transactions that are profiled. Cannot exceed the trace rate. Default: 0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
# Comma-separated span.op values dropped via Sentry's `ignoreSpans` option. Removes
# noisy framework-internal child spans (one per Express router/middleware layer) that
# dominate span volume without adding APM value. Root transactions + db/http spans
# are kept; errors and the Slack/Devin pipeline are unaffected. Default: router.express,middleware.express
SENTRY_DROPPED_SPAN_OPS=router.express,middleware.express
SENTRY_ORG_SLUG=your-sentry-org
SENTRY_PROJECT_ID=your-sentry-project-id
SENTRY_CLIENT_SECRET=your-sentry-client-secret

# Datadog
DD_API_KEY=your-datadog-api-key
DD_SITE=datadoghq.com
DD_ENV=prod
DD_SERVICE=checkout-api
DD_VERSION=1.0.0
DD_AGENT_HOST=datadog-agent
DD_TRACE_AGENT_PORT=8126
DD_DOGSTATSD_PORT=8125
DD_DASHBOARD_URL=https://app.datadoghq.com/dashboard/your-dashboard-id

# Slack (alert notifications — optional)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=C0123456789
SLACK_USER_TOKEN=xoxp-your-slack-user-token
DEVIN_SLACK_USER_ID=your-devin-slack-user-id

# Triage mirror (report-only — every bug report is also posted here, but this
# channel never triggers a Devin session). Defaults to #automated-devin-triage.
# The bot must be invited to the channel: `/invite @<bot>` in #automated-devin-triage.
SLACK_TRIAGE_CHANNEL_ID=C0B74QWEEVD
# Optional: separate bot token for the triage post (defaults to SLACK_BOT_TOKEN)
# SLACK_TRIAGE_BOT_TOKEN=xoxb-your-slack-bot-token

# Devin API (auto-investigation via v3 service key)
# DEVIN_SERVICE_KEY is the service user's API key used for all session creation.
# Sessions are created on behalf of individual users via create_as_user_id.
DEVIN_SERVICE_KEY=your-devin-service-key
DEVIN_ORG_ID=your-devin-org-id
DEVIN_ORG_NAME=Your Org Name
DEVIN_PLAYBOOK_ID=

# Optional: fallback org list when enterprise API listing is unavailable.
# JSON array of {org_id, name} objects.
# DEVIN_ORG_LIST=[{"org_id":"org_abc","name":"My Org"}]

# Optional: fallback user list when API listing is unavailable.
# JSON array of {user_id, name, email} objects.
# DEVIN_ORG_USERS=[{"user_id":"cog_abc","name":"Alice","email":"alice@example.com"}]

# GitHub Webhook
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# SonarCloud remediation target repo (default: <GITHUB_ORG>/etl-pipeline-demo)
SONAR_TARGET_REPO=

# ─── Deployment Configuration ──────────────────────────
# GitHub organization for repo references (default: COG-GTM)
GITHUB_ORG=COG-GTM

# App display title (shown in hub page header)
# APP_TITLE=Event-Driven Devin

# Lock deployment to a single Devin org (hides org selector in UI).
# Set to any non-empty value for customer-specific demos.
# When set, DEVIN_ORG_ID determines which org is used.
# LOCK_ORG=true

# Pre-configured Devin user ID (hides user selector in UI).
# When set, all sessions are created as this user.
# DEVIN_USER_ID=cog_abc123...

# ─── Per-Customer Overrides ─────────────────────────────
# Customer-specific env vars use a _<SLUG> suffix.
# See config/customers.js for registered customer slugs.
#
# Example (customer slug: "a6b38c63"):
# DEVIN_API_KEY_A6B38C63=dv-your-devin-api-key
# DEVIN_PLAYBOOK_ID_A6B38C63=
# GITHUB_ORG_A6B38C63=SomeGitHubOrg
# DEVIN_USER_ID_A6B38C63=cog_user_123
# SONAR_TARGET_REPO_A6B38C63=SomeGitHubOrg/etl-pipeline-demo

# Customer beb4d43e
# DEVIN_SERVICE_KEY_BEB4D43E=
# DEVIN_USER_ID_BEB4D43E=

# Customer 4feeb7bb
# DEVIN_SERVICE_KEY_4FEEB7BB=
# DEVIN_USER_ID_4FEEB7BB=

# Customer 89c1f355
# DEVIN_SERVICE_KEY_89C1F355=
# DEVIN_USER_ID_89C1F355=

# Customer b3e22436
# DEVIN_SERVICE_KEY_B3E22436=
# DEVIN_USER_ID_B3E22436=

# Customer a6b38c63
# DEVIN_SERVICE_KEY_A6B38C63=
# DEVIN_USER_ID_A6B38C63=

# Customer ef5d1dc1
# DEVIN_SERVICE_KEY_EF5D1DC1=
# DEVIN_USER_ID_EF5D1DC1=

# Customer d5fc3172
# DEVIN_SERVICE_KEY_D5FC3172=
# DEVIN_USER_ID_D5FC3172=

# Customer BBVA
# DEVIN_SERVICE_KEY_BBVA=
# DEVIN_USER_ID_BBVA=

# Customer Sysco
# DEVIN_SERVICE_KEY_SYSCO=
# DEVIN_USER_ID_SYSCO=
# SONAR_TARGET_REPO_SYSCO=

# Customer VF Corporation
# DEVIN_SERVICE_KEY_VFC=
# DEVIN_USER_ID_VFC=
# SONAR_TARGET_REPO_VFC=

# Customer S&P Global
# DEVIN_SERVICE_KEY_SPGLOBAL=
# DEVIN_USER_ID_SPGLOBAL=
# SONAR_TARGET_REPO_SPGLOBAL=

# Customer 841AFDC1
# DEVIN_SERVICE_KEY_841AFDC1=
# DEVIN_USER_ID_841AFDC1=

# Customer 17DD6F6F
# DEVIN_SERVICE_KEY_17DD6F6F=
# DEVIN_USER_ID_17DD6F6F=

# Customer 08381313
# DEVIN_SERVICE_KEY_08381313=
# DEVIN_USER_ID_08381313=

# Customer athenahealth
# DEVIN_SERVICE_KEY_ATHENAHEALTH=
# DEVIN_USER_ID_ATHENAHEALTH=

# Customer scotiabank
# DEVIN_SERVICE_KEY_SCOTIABANK=
# DEVIN_USER_ID_SCOTIABANK=

# Customer 4ada28b9
# DEVIN_SERVICE_KEY_4ADA28B9=
# DEVIN_USER_ID_4ADA28B9=

# Customer lingo
# DEVIN_SERVICE_KEY_LINGO=
# DEVIN_USER_ID_LINGO=

# Session creation verification
# When set, session-creating endpoints require this secret in x-session-secret header
# SESSION_SECRET=your-session-secret

# Load Generator
LOADGEN_TARGET_URL=http://localhost:3000
# How often (ms) the synthetic traffic cycle runs. Higher = less traffic = fewer spans.
# 60000 = 1 cycle/min, 300000 = 1 cycle/5min. Default: 300000
LOADGEN_INTERVAL_MS=300000
